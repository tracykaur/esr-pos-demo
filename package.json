{
  "name": "esr-clienteling-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.10"
  },
  "scripts": {
    "build": "remix vite:build",
    "dev": "shopify app dev",
    "dev:local": "remix vite:dev",
    "config:link": "shopify app config link",
    "config:use": "shopify app config use",
    "deploy": "shopify app deploy",
    "env": "shopify app env",
    "generate": "shopify app generate",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "shopify",
    "prisma": "prisma",
    "graphql-codegen": "graphql-codegen",
    "setup": "prisma generate && prisma migrate deploy",
    "seed": "node --env-file=.env --import tsx/esm scripts/seed.ts",
    "tunnel:sync": "node --env-file=.env --import tsx/esm scripts/sync-tunnel.ts",
    "start": "remix-serve ./build/server/index.js",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@preact/signals": "^2.9.0",
    "@prisma/client": "^5.20.0",
    "@remix-run/dev": "^2.16.1",
    "@remix-run/node": "^2.16.1",
    "@remix-run/react": "^2.16.1",
    "@remix-run/serve": "^2.16.1",
    "@shopify/app-bridge-react": "^4.1.6",
    "@shopify/polaris": "^13.9.0",
    "@shopify/shopify-app-remix": "^3.7.0",
    "@shopify/shopify-app-session-storage-prisma": "^6.0.0",
    "@shopify/ui-extensions": "~2026.1.3",
    "isbot": "^5.1.0",
    "preact": "^10.29.1",
    "prisma": "^5.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite-tsconfig-paths": "^5.0.1"
  },
  "devDependencies": {
    "@remix-run/route-config": "^2.16.1",
    "@shopify/api-codegen-preset": "^1.1.5",
    "@shopify/cli": "^3.94.3",
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "eslint": "^9.11.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  },
  "workspaces": [],
  "author": "Elka"
}
