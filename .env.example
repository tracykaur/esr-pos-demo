# Shopify app credentials (populated by `shopify app config link` or set manually)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://YOUR-TUNNEL.trycloudflare.com
SCOPES=read_customers,write_customers,read_orders,read_products,read_discounts,write_discounts,read_locations,read_metaobject_definitions,write_metaobject_definitions,read_metaobjects,write_metaobjects,write_metafields,read_metafields,read_customer_segments,write_customer_segments

# Prisma — SQLite for dev, swap to Postgres in prod
DATABASE_URL=file:./dev.db

# Optional: override the Admin API version (default 2026-04 per architect §0)
SHOPIFY_API_VERSION=2026-04
AI_PROXY_URL=https://proxy.shopify.ai
AI_PROXY_TOKEN=shopify-...

# Optional: pin store domain for seeding via offline session (e.g. elka-dev.myshopify.com)
SHOPIFY_SEED_SHOP=
